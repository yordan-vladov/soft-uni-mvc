@model Address

@{
    ViewData["Title"] = "Create Address";
}

<h1>Create</h1>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group mb-3">
        <label asp-for="AddressText" class="control-label"></label>
        <input asp-for="AddressText" class="form-control" />
        <span asp-validation-for="AddressText" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="TownId" class="control-label"></label>
        <select asp-for="TownId" class="form-control" asp-items="ViewBag.TownId">
            <option value="">-- Select Town --</option>
        </select>
        <span asp-validation-for="TownId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <input type="submit" value="Create" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
