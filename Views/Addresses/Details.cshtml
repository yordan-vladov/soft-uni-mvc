@model Address

@{
    ViewData["Title"] = "Address Details";
}

<h1>Details</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.AddressText)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.AddressText)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Town)</dt>
        <dd class="col-sm-10">@Model.Town?.Name</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.AddressId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
