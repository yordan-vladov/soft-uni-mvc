@model Address

@{
    ViewData["Title"] = "Delete Address";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.AddressText)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.AddressText)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Town)</dt>
        <dd class="col-sm-10">@Model.Town?.Name</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="AddressId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
